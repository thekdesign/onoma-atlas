{
    "name": "onoma-atlas",
    "private": true,
    "version": "0.1.0",
    "description": "Onoma 世界擬聲詞圖鑑：同一個聲音，各國怎麼寫、怎麼唸？用夢幻可愛的翻牌卡片收錄各國擬聲詞，點一下就用該國語言唸出來（純前端 + 瀏覽器內建語音）。",
    "main": "resources/js/index.js",
    "scripts": {
        "development": "NODE_ENV=development vite build --config vite.development.config.mjs",
        "production": "NODE_ENV=production vite-ssg build --config vite.production.config.mjs",
        "watch": "npm run development -- --watch",
        "serve": "vite --config vite.local.config.mjs",
        "lint": "npx eslint resources/js/",
        "images": "node scripts/generate-images.mjs"
    },
    "license": "ISC",
    "engines": {
        "node": ">=22"
    },
    "dependencies": {
        "@unhead/vue": "^2.0.0",
        "core-js": "^3.47.0",
        "enum": "^3.0.4",
        "pinia": "^3.0.1",
        "reset-css": "^5.0.2",
        "vue": "^3.5.22",
        "vue-router": "^4.5.0"
    },
    "devDependencies": {
        "@babel/core": "^7.28.0",
        "@babel/eslint-parser": "^7.28.0",
        "@babel/preset-env": "^7.28.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/server-renderer": "^3.5.34",
        "autoprefixer": "^10.4.20",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-import-resolver-alias": "^1.1.2",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-vue": "^9.30.0",
        "postcss": "^8.4.49",
        "sass": "^1.83.0",
        "sharp": "^0.34.0",
        "tailwindcss": "^3.4.18",
        "vite": "^7.3.3",
        "vite-ssg": "^28.3.0",
        "vue-eslint-parser": "^9.4.3"
    }
}
